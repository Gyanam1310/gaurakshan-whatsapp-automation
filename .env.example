# Compose runtime
PORT=5000
NODE_ENV=production
CORS_ORIGINS=*
REQUEST_TIMEOUT_MS=30000
LOG_LEVEL=info
LOG_MAX_SIZE_MB=10
LOG_MAX_FILES=14

# Google
DRIVE_FOLDER_ID=your_drive_parent_folder_id
GOOGLE_CREDENTIALS_FILE=./service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY=/app/config/service-account.json

# WhatsApp
GROUP_ID=120000000000000000@g.us
WHATSAPP_SESSION_DIR=/app/session
WHATSAPP_CONNECT_TIMEOUT_MS=45000
WHATSAPP_MAX_RECONNECT_ATTEMPTS=12
WHATSAPP_RECONNECT_BASE_DELAY_MS=2000
WHATSAPP_RECONNECT_MAX_DELAY_MS=60000
WHATSAPP_RECONNECT_JITTER_RATIO=0.2
WHATSAPP_SEND_TIMEOUT_MS=25000
WHATSAPP_SEND_RETRY_ATTEMPTS=2
WHATSAPP_SEND_RETRY_BASE_DELAY_MS=1500
WHATSAPP_SEND_RETRY_MAX_DELAY_MS=8000
WHATSAPP_SEND_RETRY_JITTER_RATIO=0.2

# Queue (optional, disabled by default)
QUEUE_ENABLED=false
REDIS_URL=redis://redis:6379
BULLMQ_QUEUE_NAME=whatsapp-send

# n8n
N8N_HOST=localhost
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678
GENERIC_TIMEZONE=Asia/Kolkata
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=strongpassword
